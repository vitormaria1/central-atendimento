## App
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

## URL pública (usada para configurar webhook na UAZAPI)
PUBLIC_APP_URL=https://prazer.varinteligencia.com

## Auth
SESSION_SECRET=change-me-long-random-string
AGENT_VANDERLEI_PIN=1234
AGENT_GUSTAVO_PIN=5678

## UAZAPI
UAZAPI_BASE_URL=https://varia.uazapi.com
UAZAPI_INSTANCE_NAME=juninho
UAZAPI_TOKEN=change-me
# Opcional: se seus endpoints forem diferentes (padrão pela doc v2.1.0)
UAZAPI_CHAT_FIND_PATH=/chat/find
UAZAPI_MESSAGE_FIND_PATH=/message/find
UAZAPI_SEND_TEXT_PATH=/send/text

## Database
DATABASE_URL=postgres://postgres:postgres@db:5432/central_atendimento

## Fiscal / Financeiro
FOCUS_BASE_URL=https://api.focusnfe.com.br
FOCUS_API_KEY=change-me
INTER_BASE_URL=https://cdpj.partners.bancointer.com.br
INTER_CLIENT_ID=change-me
INTER_CLIENT_SECRET=change-me
INTER_CERTIFICATE_PATH=/run/secrets/inter-cert.p12
BILLING_NOTIFY_EMAIL_FROM=financeiro@exemplo.com
BILLING_NOTIFY_WHATSAPP_FROM=5511999999999

## IA (Gemini)
GEMINI_API_KEY=change-me
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-pro
